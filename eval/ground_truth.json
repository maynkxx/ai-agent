    ],
    "graduate_employment": [
      {"mode": "null_ok", "path": "employed_within_6_months_pct"},
      {"mode": "present", "path": "source"}
    ],
    "average_salaries": [
      {"mode": "list_min", "n": 1, "keys": ["median_salary"]},
      {"mode": "any_num", "field": "median_salary", "expected": 126438, "tol_rel": 0.05}
    ],
    "visa_policies": [
      {"mode": "contains", "path": "visa_type", "expected": "I-20"},
