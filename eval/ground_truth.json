{
  "_about": "Hand-verified ground truth for the eval harness. Each field lists independent CHECKS run against the agent's output by eval/evaluate.py. Values were verified against the official source pages (the same pages the agent scrapes). Where a source genuinely does not publish a value, the check mode is 'null_ok'/'empty_ok' so the agent is rewarded for an honest null and NOT penalised for a gap it could not fill.",
  "mit": {
    "about": [
      {"mode": "num", "path": "founding_year", "expected": 1861},
      {"mode": "exact", "path": "type", "expected": "private"},
      {"mode": "contains", "path": "location", "expected": "Cambridge"}
    ],
    "tuition_fees": [
      {"mode": "list_min", "n": 2, "keys": ["program_level", "international_annual"]},
      {"mode": "any_num", "field": "international_annual", "expected": 64730, "tol_rel": 0.02}
    ],
    "living_costs": [
      {"mode": "exact", "path": "currency", "expected": "USD"},
      {"mode": "num", "path": "rent", "expected": 1425, "tol_rel": 0.1},
      {"mode": "present", "path": "total"}
    ],
    "scholarships": [
