      {"mode": "list_contains", "field": "close_date", "expected": "January 5"}
    ],
    "course_listings": [
      {"mode": "list_min", "n": 8, "keys": ["code", "title"]},
      {"mode": "list_contains", "field": "code", "expected": "6.100A"}
    ]
  },
